// =============================================================================
// StoryForge AI — Prisma Schema
// Database: PostgreSQL 16
// Convention: camelCase in TypeScript, snake_case in PostgreSQL (@map)
// =============================================================================

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// =============================================================================
// USERS
// =============================================================================

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  username  String   @unique
  password  String
  role      UserRole @default(USER)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  stories           Story[]
  settings          Setting[]
  clipForgeProjects ClipForgeProject[]

  @@index([email])
  @@index([isActive])
  @@map("users")
}

enum UserRole {
  ADMIN
  USER
  VIEWER
}

// =============================================================================
// STORIES
// =============================================================================

model Story {
  id             String          @id @default(uuid())
  userId         String          @map("user_id")
  title          String
  genre          StoryGenre
  style          ImageStyle      @default(ANIME)
  language       ContentLanguage @default(EN) @map("language")
  synopsis       String          @db.Text
  targetAudience String          @default("13-35") @map("target_audience")
  isActive       Boolean         @default(true) @map("is_active")
  episodeCount   Int             @default(0) @map("episode_count")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  episodes   Episode[]
  characters Character[]
  locations  Location[]
  memory     StoryMemory?

  @@index([userId])
  @@index([isActive])
  @@index([genre])
  @@index([language])
  @@map("stories")
}

enum ContentLanguage {
  EN
  HI
  TE
}

enum StoryGenre {
  ACTION
  ADVENTURE
  ROMANCE
  HORROR
  MYSTERY
  FANTASY
  SCI_FI
  DRAMA
  COMEDY
  THRILLER
}

enum ImageStyle {
  ANIME
  CARTOON
  CINEMATIC
  REALISTIC
}

model StoryMemory {
  id         String   @id @default(uuid())
  storyId    String   @unique @map("story_id")
  timeline   Json     @default("[]")
  worldState Json     @default("{}") @map("world_state")
  plotPoints Json     @default("[]") @map("plot_points")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@map("story_memory")
}

// =============================================================================
// EPISODES
// =============================================================================

model Episode {
  id              String        @id @default(uuid())
  storyId         String        @map("story_id")
  episodeNumber   Int           @map("episode_number")
  title           String
  content         String        @db.Text
  hook            String        @db.Text
  cliffhanger     String        @db.Text
  duration        Int           @default(40)
  status          EpisodeStatus @default(PENDING)
  processingError String?       @map("processing_error") @db.Text
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  story        Story         @relation(fields: [storyId], references: [id], onDelete: Cascade)
  scenes       Scene[]
  audioFile    AudioFile?
  subtitleFile SubtitleFile?
  video        Video?
  prompts      Prompt[]

  @@unique([storyId, episodeNumber])
  @@index([storyId])
  @@index([status])
  @@index([createdAt])
  @@map("episodes")
}

enum EpisodeStatus {
  PENDING
  GENERATING_STORY
  GENERATING_SCENES
  GENERATING_PROMPTS
  GENERATING_IMAGES
  GENERATING_AUDIO
  GENERATING_SUBTITLES
  COMPOSING_VIDEO
  GENERATING_SEO
  UPLOADING
  PUBLISHED
  FAILED
}

// =============================================================================
// SCENES
// =============================================================================

model Scene {
  id          String   @id @default(uuid())
  episodeId   String   @map("episode_id")
  sceneNumber Int      @map("scene_number")
  description String   @db.Text
  narration   String   @db.Text
  mood        String
  duration    Int
  characters  Json     @default("[]")
  location    String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  episode Episode         @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  prompt  Prompt?
  image   GeneratedImage?

  @@unique([episodeId, sceneNumber])
  @@index([episodeId])
  @@map("scenes")
}

// =============================================================================
// CHARACTERS & LOCATIONS
// =============================================================================

model Character {
  id                String   @id @default(uuid())
  storyId           String   @map("story_id")
  name              String
  description       String   @db.Text
  visualDescription String   @map("visual_description") @db.Text
  personality       String   @db.Text
  role              String
  appearances       Int      @default(0)
  isAlive           Boolean  @default(true) @map("is_alive")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@unique([storyId, name])
  @@index([storyId])
  @@map("characters")
}

model Location {
  id                String   @id @default(uuid())
  storyId           String   @map("story_id")
  name              String
  description       String   @db.Text
  visualDescription String   @map("visual_description") @db.Text
  appearances       Int      @default(0)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@unique([storyId, name])
  @@index([storyId])
  @@map("locations")
}

// =============================================================================
// PROMPTS & IMAGES
// =============================================================================

model Prompt {
  id             String     @id @default(uuid())
  episodeId      String     @map("episode_id")
  sceneId        String?    @unique @map("scene_id")
  type           PromptType @default(SCENE)
  positivePrompt String     @map("positive_prompt") @db.Text
  negativePrompt String     @default("") @map("negative_prompt") @db.Text
  style          String
  characters     Json       @default("[]")
  location       String?
  mood           String?
  model          String     @default("stable-diffusion")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  episode Episode          @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  scene   Scene?           @relation(fields: [sceneId], references: [id])
  images  GeneratedImage[]

  @@index([episodeId])
  @@map("prompts")
}

enum PromptType {
  SCENE
  CHARACTER
  THUMBNAIL
}

model GeneratedImage {
  id        String      @id @default(uuid())
  promptId  String      @map("prompt_id")
  sceneId   String?     @unique @map("scene_id")
  filename  String
  localPath String      @map("local_path")
  s3Key     String?     @map("s3_key")
  s3Url     String?     @map("s3_url")
  width     Int         @default(1080)
  height    Int         @default(1920)
  seed      Int?
  model     String
  status    ImageStatus @default(PENDING)
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  prompt Prompt @relation(fields: [promptId], references: [id], onDelete: Cascade)
  scene  Scene? @relation(fields: [sceneId], references: [id])

  @@index([promptId])
  @@index([status])
  @@map("generated_images")
}

enum ImageStatus {
  PENDING
  GENERATING
  COMPLETED
  FAILED
}

// =============================================================================
// AUDIO FILES
// =============================================================================

model AudioFile {
  id         String      @id @default(uuid())
  episodeId  String      @unique @map("episode_id")
  filename   String
  localPath  String      @map("local_path")
  s3Key      String?     @map("s3_key")
  s3Url      String?     @map("s3_url")
  duration   Float
  voice      String      @default("en_US-lessac-medium")
  sampleRate Int         @default(22050) @map("sample_rate")
  status     AudioStatus @default(PENDING)
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")

  episode Episode @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  @@map("audio_files")
}

enum AudioStatus {
  PENDING
  GENERATING
  COMPLETED
  FAILED
}

// =============================================================================
// SUBTITLE FILES
// =============================================================================

model SubtitleFile {
  id        String         @id @default(uuid())
  episodeId String         @unique @map("episode_id")
  filename  String
  localPath String         @map("local_path")
  s3Key     String?        @map("s3_key")
  s3Url     String?        @map("s3_url")
  language  String         @default("en")
  format    SubtitleFormat @default(SRT)
  status    SubtitleStatus @default(PENDING)
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")

  episode Episode @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  @@map("subtitle_files")
}

enum SubtitleFormat {
  SRT
  VTT
  ASS
}

enum SubtitleStatus {
  PENDING
  GENERATING
  COMPLETED
  FAILED
}

// =============================================================================
// VIDEOS
// =============================================================================

model Video {
  id             String      @id @default(uuid())
  episodeId      String      @unique @map("episode_id")
  filename       String
  localPath      String      @map("local_path")
  s3Key          String?     @map("s3_key")
  s3Url          String?     @map("s3_url")
  duration       Float
  width          Int         @default(1080)
  height         Int         @default(1920)
  fps            Int         @default(30)
  codec          String      @default("h264")
  fileSize       BigInt      @map("file_size")
  thumbnailPath  String?     @map("thumbnail_path")
  thumbnailS3Key String?     @map("thumbnail_s3_key")
  thumbnailS3Url String?     @map("thumbnail_s3_url")
  status         VideoStatus @default(PENDING)
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  episode     Episode      @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  seoMetadata SeoMetadata?
  uploads     Upload[]

  @@index([status])
  @@map("videos")
}

enum VideoStatus {
  PENDING
  COMPOSING
  COMPLETED
  FAILED
}

// =============================================================================
// SEO METADATA
// =============================================================================

model SeoMetadata {
  id          String   @id @default(uuid())
  videoId     String   @unique @map("video_id")
  title       String
  description String   @db.Text
  tags        String[]
  hashtags    String[]
  category    String   @default("Entertainment")
  language    String   @default("en")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@map("seo_metadata")
}

// =============================================================================
// UPLOADS
// =============================================================================

model Upload {
  id              String       @id @default(uuid())
  videoId         String       @map("video_id")
  platform        Platform
  platformVideoId String?      @map("platform_video_id")
  platformUrl     String?      @map("platform_url")
  status          UploadStatus @default(PENDING)
  error           String?      @db.Text
  publishedAt     DateTime?    @map("published_at")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  video     Video       @relation(fields: [videoId], references: [id], onDelete: Cascade)
  analytics Analytics[]

  @@index([videoId])
  @@index([platform])
  @@index([status])
  @@map("uploads")
}

enum Platform {
  YOUTUBE
}

enum UploadStatus {
  PENDING
  UPLOADING
  PUBLISHED
  FAILED
  SCHEDULED
}

// =============================================================================
// ANALYTICS
// =============================================================================

model Analytics {
  id           String   @id @default(uuid())
  uploadId     String   @map("upload_id")
  views        Int      @default(0)
  likes        Int      @default(0)
  comments     Int      @default(0)
  shares       Int      @default(0)
  saves        Int      @default(0)
  watchTime    Float    @default(0) @map("watch_time")
  avgRetention Float    @default(0) @map("avg_retention")
  ctr          Float    @default(0)
  impressions  Int      @default(0)
  collectedAt  DateTime @default(now()) @map("collected_at")
  createdAt    DateTime @default(now()) @map("created_at")

  upload Upload @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  @@index([uploadId])
  @@index([collectedAt])
  @@map("analytics")
}

// =============================================================================
// SETTINGS
// =============================================================================

model Setting {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  key       String
  value     Json
  isSystem  Boolean  @default(false) @map("is_system")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([key])
  @@map("settings")
}

// =============================================================================
// CLIP FORGE — continuous YouTube-Shorts pipeline
// =============================================================================

model ClipForgeProject {
  id     String @id @default(uuid())
  userId String @map("user_id")

  // Source
  sourceUrl         String   @map("source_url")
  sourceVideoId     String   @map("source_video_id")
  sourceTitle       String   @map("source_title") @db.Text
  sourceDuration    Float?   @map("source_duration")
  sourceWidth       Int?     @map("source_width")
  sourceHeight      Int?     @map("source_height")
  sourceFps         Int?     @map("source_fps")
  sourceHasAudio    Boolean? @map("source_has_audio")
  sourceStoragePath String?  @map("source_storage_path")
  sourceFingerprint String?  @map("source_fingerprint")

  // Split plan
  targetShortDuration Float @default(60) @map("target_short_duration")
  totalParts          Int   @default(0) @map("total_parts")

  // Pipeline state
  status                   ClipForgeProjectStatus @default(CREATED)
  continuityValidated      Boolean                @default(false) @map("continuity_validated")
  lastSuccessfulPartNumber Int?                   @map("last_successful_part_number")
  failureReason            String?                @map("failure_reason") @db.Text

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")
  failedAt    DateTime? @map("failed_at")

  user                  User                            @relation(fields: [userId], references: [id], onDelete: Cascade)
  parts                 ClipForgePart[]
  continuityValidations ClipForgeContinuityValidation[]

  @@index([userId])
  @@index([status])
  @@index([sourceVideoId])
  @@map("clip_forge_projects")
}

enum ClipForgeProjectStatus {
  CREATED
  SOURCE_VALIDATING
  SOURCE_READY
  SPLIT_PLANNING
  CONTINUITY_VALIDATING
  PROCESSING
  UPLOADING
  WAITING_FOR_YOUTUBE_QUOTA
  PARTIALLY_COMPLETED
  COMPLETED
  FAILED
  CONTINUITY_VALIDATION_FAILED
}

model ClipForgePart {
  id        String @id @default(uuid())
  projectId String @map("project_id")

  partNumber Int    @map("part_number")
  partLabel  String @map("part_label")
  totalParts Int    @map("total_parts")

  startTime Float @map("start_time")
  endTime   Float @map("end_time")
  duration  Float

  seoTitle    String? @map("seo_title") @db.Text
  description String? @db.Text

  status ClipForgePartStatus @default(PENDING)

  renderedStoragePath String? @map("rendered_storage_path")

  youtubeVideoId  String? @map("youtube_video_id")
  youtubeVideoUrl String? @map("youtube_video_url")

  uploadAttempts  Int     @default(0) @map("upload_attempts")
  lastUploadError String? @map("last_upload_error") @db.Text

  renderStartedAt   DateTime? @map("render_started_at")
  renderCompletedAt DateTime? @map("render_completed_at")
  uploadedAt        DateTime? @map("uploaded_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project ClipForgeProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, partNumber])
  @@index([projectId])
  @@index([status])
  @@map("clip_forge_parts")
}

enum ClipForgePartStatus {
  PENDING
  RENDERING
  RENDERED
  STORED
  SEO_TITLE_GENERATING
  SEO_TITLE_READY
  UPLOAD_PENDING
  UPLOADING
  UPLOADED
  FAILED
  COMPLETED
}

model ClipForgeContinuityValidation {
  id        String @id @default(uuid())
  projectId String @map("project_id")

  valid           Boolean @default(false)
  sourceDuration  Float   @map("source_duration")
  coveredDuration Float   @map("covered_duration")

  missingRangesJson     Json @default("[]") @map("missing_ranges_json")
  overlapRangesJson     Json @default("[]") @map("overlap_ranges_json")
  duplicateRangesJson   Json @default("[]") @map("duplicate_ranges_json")
  validationDetailsJson Json @default("{}") @map("validation_details_json")

  createdAt DateTime @default(now()) @map("created_at")

  project ClipForgeProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("clip_forge_continuity_validations")
}
