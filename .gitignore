# ─── Dependencies ─────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ─── Build outputs ────────────────────────────────────────────────────────────
dist/
build/
out/
.next/

# ─── TypeScript incremental build cache ──────────────────────────────────────
*.tsbuildinfo
tsconfig.tsbuildinfo

# ─── Environment / secrets (NEVER commit real env files) ─────────────────────
.env
.env.local
.env.*.local
.env.docker
# Keep the examples so new devs know what vars are needed
!.env.example
!.env.docker.example

# ─── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ─── OS files ─────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini
*.swp
*.swo
*~

# ─── IDE / editor ────────────────────────────────────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
.fleet/
*.code-workspace

# ─── AI / generated content (large runtime files) ────────────────────────────
# Images, audio, video, subtitles produced by the pipeline at runtime
generated/
!generated/.gitkeep

# ─── ML model weights (large binary downloads) ───────────────────────────────
models/
!models/.gitkeep
# faster-whisper model cache (downloaded at runtime)
.cache/
**/whisper_cache/
**/.cache/huggingface/

# ─── Prisma / database ───────────────────────────────────────────────────────
packages/database/node_modules/
packages/database/dist/
# Local SQLite dev database (if used)
*.db
*.sqlite
*.sqlite3

# ─── Test coverage ───────────────────────────────────────────────────────────
coverage/
*.lcov
.nyc_output/

# ─── Playwright e2e test artifacts ───────────────────────────────────────────
test-results/
playwright-report/
playwright/.cache/
# Keep e2e source files — only ignore runtime output
apps/web/test-results/
apps/web/playwright-report/

# ─── Turbo cache ─────────────────────────────────────────────────────────────
.turbo/

# ─── Docker volumes / data ───────────────────────────────────────────────────
docker/postgres/data/
docker/redis/data/
docker/data/

# ─── Temp / scratch files ────────────────────────────────────────────────────
tmp/
temp/
*.tmp
*.temp
*.bak
*.backup
*.orig

# ─── Python artifacts (subtitle-agent / whisper) ─────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
*.egg-info/
dist-info/
venv/
.venv/
pip-wheel-metadata/

# ─── FFmpeg temporary artifacts (video pipeline) ─────────────────────────────
# concat list files and intermediate clips written by the video agent
**/concat_list.txt
**/clip_*.mp4
**/clip_*.ts

# ─── Supabase local ──────────────────────────────────────────────────────────
.supabase/

# ─── Package manager lock files (keep only one) ──────────────────────────────
# Uncomment whichever you are NOT using to avoid committing both:
# yarn.lock
# pnpm-lock.yaml

# ─── Miscellaneous ───────────────────────────────────────────────────────────
*.pem
*.p12
*.key
*.cert
*.crt
# Google service account keys
*service-account*.json
*credentials*.json
# Never commit YouTube / OAuth tokens
*token*.json
*refresh_token*

# ─── Error screenshots (project-specific) ────────────────────────────────────
error/

# ─── Local Scratch/Command files ─────────────────────────────────────────────
runcommends
*commands*
*commends*

