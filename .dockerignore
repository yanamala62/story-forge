# Dependencies — reinstalled inside the image; copying host node_modules
# would bake in host-OS native binaries (e.g. prisma engines) and bloat context.
node_modules/
**/node_modules/

# Version control — not needed at runtime, and .git can be large.
.git/
.gitignore

# Turborepo cache — host-machine build cache, invalid/irrelevant inside a container.
.turbo/
**/.turbo/

# Build outputs — regenerated by `turbo run build` inside the image;
# shipping stale host-built dist/ risks running artifacts that don't match the source copied in.
dist/
**/dist/
*.tsbuildinfo

# Test artifacts — Playwright/Jest output, never needed to build or run the app.
coverage/
**/coverage/
playwright-report/
**/playwright-report/
test-results/
**/test-results/
apps/web/e2e/screenshots/

# Generated AI content — large per-story media (audio/images/subtitles/video).
# Regenerated at runtime or fetched from Supabase Storage; must never ship in the image.
generated/
**/generated/

# Local model weights/caches — large binaries; Whisper etc. are fetched at runtime instead.
models/
**/models/

# Environment files — contain secrets; must be injected at deploy time, never baked into a layer.
.env
.env.*
!.env.example

# Logs and local temp/cache files.
logs/
**/logs/
*.log
tmp/
temp/
*.tmp

# Editor/OS cruft.
.vscode/
.idea/
.DS_Store
Thumbs.db

# Docs and local dev tooling not needed to build/run.
README*.md
docker-compose*.yml

# Frontend workspace — the only Dockerfile in this repo builds apps/api.
# Excluding apps/web entirely (not just node_modules) keeps it from ever
# being discovered as an npm workspace mid-build, which otherwise pulls
# its React/UI dependencies into the backend image via hoisting.
apps/web/
