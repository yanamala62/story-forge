# =============================================================================
# StoryForge AI — Web (frontend) Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# Origin of the deployed API (no trailing slash, no /api suffix).
# Leave EMPTY for local development — the Vite dev server proxies /api and
# /health to http://localhost:3000 (see vite.config.ts), so relative paths
# work without this being set.
#
# Set this only for production builds, e.g.:
#   VITE_API_URL=https://storyforge-api.onrender.com
VITE_API_URL=
