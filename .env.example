
# =============================================================================
# StoryForge AI — Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# APP
# -----------------------------------------------------------------------------
NODE_ENV=development
APP_PORT=3000
APP_HOST=0.0.0.0
APP_NAME=StoryForge AI
APP_VERSION=1.0.0
LOG_LEVEL=info
# Off by default — set to true only if something outside the platform's
# stdout/stderr capture (Render, Docker logs, etc.) needs to read log files.
LOG_TO_FILE=false

# -----------------------------------------------------------------------------
# DATABASE — Supabase PostgreSQL
# Get both from: Supabase Dashboard -> Project Settings -> Database -> Connection String
#   DATABASE_URL = "Transaction pooler" URI (port 6543, used by the running app)
#   DIRECT_URL   = "Direct connection" URI (port 5432, used only for prisma db push/migrate)
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# -----------------------------------------------------------------------------
# OPENROUTER (Free cloud LLM — https://openrouter.ai/keys) — the only LLM
# provider this app uses; OPENROUTER_API_KEY is required.
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=
OPENROUTER_STORY_MODEL=qwen/qwen3-next-80b-a3b-instruct:free
OPENROUTER_SEO_MODEL=qwen/qwen3-next-80b-a3b-instruct:free
# Tried in order if the primary model above is rate-limited or unavailable
OPENROUTER_FALLBACK_MODELS=google/gemma-3-27b-it:free,deepseek/deepseek-chat-v3-0324:free,openai/gpt-oss-20b:free
OPENROUTER_TIMEOUT_MS=120000
OPENROUTER_MAX_RETRIES=3

# -----------------------------------------------------------------------------
# WHISPER (Subtitles)
# -----------------------------------------------------------------------------
WHISPER_MODEL=tiny.en
WHISPER_LANGUAGE=en
WHISPER_DEVICE=cpu

# -----------------------------------------------------------------------------
# FFMPEG (Video Composition)
# -----------------------------------------------------------------------------
FFMPEG_BINARY_PATH=ffmpeg
FFPROBE_BINARY_PATH=ffprobe
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920
VIDEO_FPS=30
VIDEO_CODEC=libx264
VIDEO_CRF=23
AUDIO_CODEC=aac
AUDIO_BITRATE=128k

# -----------------------------------------------------------------------------
# STORAGE
# -----------------------------------------------------------------------------
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./generated
# Supabase Storage — set STORAGE_TYPE=supabase to enable.
# Generated files (images/audio/subtitles/video) are uploaded to the bucket
# below and deleted from local disk immediately after each pipeline stage;
# they're re-downloaded to a local temp path only when a later stage needs
# them (e.g. video composition, YouTube upload).
#   SUPABASE_URL        = https://<project-ref>.supabase.co (project URL, no path suffix)
#   SUPABASE_SECRET_KEY = a Supabase secret/service key (Project Settings -> API)
#   SUPABASE_BUCKET     = your Storage bucket name — must be set to Public
#                         (Storage -> bucket -> Settings) so stored s3Url values
#                         are directly usable
SUPABASE_URL=
SUPABASE_SECRET_KEY=
SUPABASE_BUCKET=storyforge

# -----------------------------------------------------------------------------
# STORY GENERATION
# -----------------------------------------------------------------------------
STORY_MAX_SCENES=6
STORY_EPISODE_DURATION_SECONDS=40
STORY_TARGET_AUDIENCE=13-35
STORY_IMAGE_STYLE=anime

# -----------------------------------------------------------------------------
# YOUTUBE — https://console.cloud.google.com → YouTube Data API v3 → OAuth 2.0
# -----------------------------------------------------------------------------
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_CHANNEL_ID=

# -----------------------------------------------------------------------------
# JWT (Auth — M13 SaaS)
# -----------------------------------------------------------------------------
JWT_SECRET=change_this_to_a_random_256_bit_secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:5173,http://localhost:3001
