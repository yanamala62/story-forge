
# =============================================================================
# StoryForge AI — Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# APP
# -----------------------------------------------------------------------------
NODE_ENV=development
APP_PORT=3000
APP_HOST=0.0.0.0
APP_NAME=StoryForge AI
APP_VERSION=1.0.0
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# DATABASE (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://storyforge:storyforge_password@localhost:5433/storyforge_db
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# -----------------------------------------------------------------------------
# REDIS
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=storyforge_redis_password
REDIS_DB=0
REDIS_URL=redis://:storyforge_redis_password@localhost:6379/0

# -----------------------------------------------------------------------------
# OLLAMA (Local LLM)
# -----------------------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_STORY_MODEL=qwen3:8b
OLLAMA_SEO_MODEL=llama3:8b
OLLAMA_TIMEOUT_MS=120000
OLLAMA_MAX_RETRIES=3

# -----------------------------------------------------------------------------
# COMFYUI (Image Generation)
# -----------------------------------------------------------------------------
COMFYUI_BASE_URL=http://localhost:8188
COMFYUI_TIMEOUT_MS=300000
COMFYUI_MAX_RETRIES=3
COMFYUI_WORKFLOW_PATH=./prompts/comfyui/anime_workflow.json

# -----------------------------------------------------------------------------
# PIPER TTS (Narration)
# -----------------------------------------------------------------------------
PIPER_BINARY_PATH=/usr/local/bin/piper
PIPER_MODEL_PATH=./models/piper/en_US-lessac-medium.onnx
PIPER_VOICE=en_US-lessac-medium
PIPER_SAMPLE_RATE=22050

# -----------------------------------------------------------------------------
# WHISPER (Subtitles)
# -----------------------------------------------------------------------------
WHISPER_MODEL=base.en
WHISPER_LANGUAGE=en
WHISPER_DEVICE=cpu

# -----------------------------------------------------------------------------
# FFMPEG (Video Composition)
# -----------------------------------------------------------------------------
FFMPEG_BINARY_PATH=ffmpeg
FFPROBE_BINARY_PATH=ffprobe
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920
VIDEO_FPS=30
VIDEO_CODEC=libx264
VIDEO_CRF=23
AUDIO_CODEC=aac
AUDIO_BITRATE=128k

# -----------------------------------------------------------------------------
# STORAGE
# -----------------------------------------------------------------------------
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./generated
# S3 (optional - fill if STORAGE_TYPE=s3)
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=storyforge
S3_REGION=us-east-1
S3_PUBLIC_URL=

# -----------------------------------------------------------------------------
# QUEUE (BullMQ)
# -----------------------------------------------------------------------------
QUEUE_CONCURRENCY=2
QUEUE_MAX_RETRIES=3
QUEUE_RETRY_DELAY_MS=5000
QUEUE_JOB_TIMEOUT_MS=600000

# -----------------------------------------------------------------------------
# STORY GENERATION
# -----------------------------------------------------------------------------
STORY_MAX_SCENES=6
STORY_EPISODE_DURATION_SECONDS=40
STORY_TARGET_AUDIENCE=13-35
STORY_IMAGE_STYLE=anime

# -----------------------------------------------------------------------------
# SOCIAL MEDIA (fill when needed — M10)
# -----------------------------------------------------------------------------
# YouTube
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_CHANNEL_ID=

# Instagram
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# TikTok
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=

# Facebook
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=

# -----------------------------------------------------------------------------
# JWT (Auth — M13 SaaS)
# -----------------------------------------------------------------------------
JWT_SECRET=change_this_to_a_random_256_bit_secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:5173,http://localhost:3001
