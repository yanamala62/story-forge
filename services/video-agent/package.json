  },
  "dependencies": {
    "@storyforge/database": "*",
    "@storyforge/shared": "*",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.2"
  }
